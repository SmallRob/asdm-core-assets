{
  "name": "filesystem-mcp-server",
  "description": "MCP server for filesystem operations - read/write files, manage directories, search files",
  "version": "2026.1.14",
  "transport": "stdio",
  "package": "@modelcontextprotocol/server-filesystem",
  "tools": [
    {
      "name": "read_text_file",
      "description": "Read the complete contents of a file as text. Always returns UTF-8 text. Cannot specify both head and tail.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string",
            "description": "The path to the file to read"
          },
          "head": {
            "type": "number",
            "description": "Read only the first N lines of the file"
          },
          "tail": {
            "type": "number",
            "description": "Read only the last N lines of the file"
          }
        },
        "required": ["path"]
      },
      "annotations": {
        "readOnlyHint": true
      }
    },
    {
      "name": "read_media_file",
      "description": "Read an image or audio file and return its base64-encoded data along with MIME type.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string",
            "description": "The path to the media file to read"
          }
        },
        "required": ["path"]
      },
      "annotations": {
        "readOnlyHint": true
      }
    },
    {
      "name": "read_multiple_files",
      "description": "Read multiple files simultaneously. Individual file errors do not stop the operation.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "paths": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Array of file paths to read"
          }
        },
        "required": ["paths"]
      },
      "annotations": {
        "readOnlyHint": true
      }
    },
    {
      "name": "write_file",
      "description": "Create a new file or completely overwrite an existing file with new content.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string",
            "description": "The path where the file should be written"
          },
          "content": {
            "type": "string",
            "description": "The content to write to the file"
          }
        },
        "required": ["path", "content"]
      },
      "annotations": {
        "readOnlyHint": false,
        "destructiveHint": true
      }
    },
    {
      "name": "edit_file",
      "description": "Make selective edits to a file using pattern matching. Supports multi-line matching and preserves indentation. Use dryRun first to preview changes.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string",
            "description": "The path to the file to edit"
          },
          "edits": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "oldText": { "type": "string", "description": "Text to find and replace" },
                "newText": { "type": "string", "description": "Text to replace with" }
              },
              "required": ["oldText", "newText"]
            },
            "description": "Array of edit operations"
          },
          "dryRun": {
            "type": "boolean",
            "description": "If true, preview changes without applying them",
            "default": false
          }
        },
        "required": ["path", "edits"]
      },
      "annotations": {
        "readOnlyHint": false,
        "destructiveHint": true
      }
    },
    {
      "name": "create_directory",
      "description": "Create a new directory or ensure a directory exists. Idempotent - does not fail if directory already exists.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string",
            "description": "The path of the directory to create"
          }
        },
        "required": ["path"]
      },
      "annotations": {
        "readOnlyHint": false,
        "destructiveHint": false
      }
    },
    {
      "name": "list_directory",
      "description": "List the contents of a directory. Returns entries with [FILE] or [DIR] prefix.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string",
            "description": "The path of the directory to list"
          }
        },
        "required": ["path"]
      },
      "annotations": {
        "readOnlyHint": true
      }
    },
    {
      "name": "list_directory_with_sizes",
      "description": "List directory contents with file sizes. Optionally sort by name or size.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string",
            "description": "The path of the directory to list"
          },
          "sortBy": {
            "type": "string",
            "enum": ["name", "size"],
            "description": "Sort entries by name or size"
          }
        },
        "required": ["path"]
      },
      "annotations": {
        "readOnlyHint": true
      }
    },
    {
      "name": "move_file",
      "description": "Move or rename a file or directory. Fails if destination already exists.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "source": {
            "type": "string",
            "description": "The source path"
          },
          "destination": {
            "type": "string",
            "description": "The destination path"
          }
        },
        "required": ["source", "destination"]
      },
      "annotations": {
        "readOnlyHint": false
      }
    },
    {
      "name": "search_files",
      "description": "Recursively search for files and directories matching a pattern.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string",
            "description": "The directory to search in"
          },
          "pattern": {
            "type": "string",
            "description": "Glob pattern to match files/directories"
          },
          "excludePatterns": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Patterns to exclude from search"
          }
        },
        "required": ["path", "pattern"]
      },
      "annotations": {
        "readOnlyHint": true
      }
    },
    {
      "name": "directory_tree",
      "description": "Get a recursive tree structure of a directory in JSON format.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string",
            "description": "The root directory path"
          },
          "excludePatterns": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Patterns to exclude from the tree"
          }
        },
        "required": ["path"]
      },
      "annotations": {
        "readOnlyHint": true
      }
    },
    {
      "name": "get_file_info",
      "description": "Get detailed metadata about a file or directory including size, timestamps, and permissions.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string",
            "description": "The path to get info for"
          }
        },
        "required": ["path"]
      },
      "annotations": {
        "readOnlyHint": true
      }
    },
    {
      "name": "list_allowed_directories",
      "description": "List all directories that this server is allowed to access.",
      "inputSchema": {
        "type": "object",
        "properties": {}
      },
      "annotations": {
        "readOnlyHint": true
      }
    }
  ],
  "configTemplates": {
    "claude_desktop": {
      "mcpServers": {
        "filesystem": {
          "command": "npx",
          "args": [
            "-y",
            "@modelcontextprotocol/server-filesystem",
            "/path/to/allowed/dir"
          ]
        }
      }
    },
    "vscode": {
      "servers": {
        "filesystem": {
          "command": "npx",
          "args": [
            "-y",
            "@modelcontextprotocol/server-filesystem",
            "${workspaceFolder}"
          ]
        }
      }
    },
    "cursor": {
      "mcpServers": {
        "filesystem": {
          "command": "npx",
          "args": [
            "-y",
            "@modelcontextprotocol/server-filesystem",
            "/path/to/project"
          ]
        }
      }
    },
    "docker": {
      "mcpServers": {
        "filesystem": {
          "command": "docker",
          "args": [
            "run",
            "-i",
            "--rm",
            "--mount", "type=bind,src=/host/path,dst=/projects/path",
            "mcp/filesystem",
            "/projects"
          ]
        }
      }
    }
  }
}